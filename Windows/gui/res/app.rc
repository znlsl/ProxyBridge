// Log Filter (edit) sub-dialog
IDD_FILTER DIALOGEX 0, 0, 280, 178
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Log Filter Rule"
FONT 11, "Segoe UI", 400, 0, 0x0
BEGIN
    LTEXT           "Mode:",     IDC_FE_L_MODE,    8,  12, 60, 10
    COMBOBOX        IDC_FE_MODE,  80,  10, 120, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Process:",  IDC_FE_L_PROC,    8,  34, 60, 10
    EDITTEXT        IDC_FE_PROC,  80,  32, 190, 13, ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT           "IP:",       IDC_FE_L_IP,      8,  56, 60, 10
    EDITTEXT        IDC_FE_IP,    80,  54, 190, 13, ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT           "Port:",     IDC_FE_L_PORT,    8,  78, 60, 10
    EDITTEXT        IDC_FE_PORT,  80,  76, 190, 13, ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT           "Protocol:", IDC_FE_L_PROTO,   8, 100, 60, 10
    COMBOBOX        IDC_FE_PROTO, 80,  98, 120, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Action:",   IDC_FE_L_ACTION,  8, 122, 60, 10
    COMBOBOX        IDC_FE_ACTION,80, 120, 120, 90, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    DEFPUSHBUTTON   "OK",        IDOK,           164, 152, 52, 14
    PUSHBUTTON      "Cancel",    IDCANCEL,       220, 152, 52, 14
END

// Update notification dialog
IDD_UPDATE DIALOGEX 0, 0, 300, 176
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Software Update"
FONT 11, "Segoe UI", 400, 0, 0x0
BEGIN
    CTEXT           "",  IDC_UP_TEXT,     10,  12, 280, 22
    CTEXT           "",  IDC_UP_VERS,     10,  42, 280, 12
    CTEXT           "",  IDC_UP_DATE,     10,  58, 280, 11
    CONTROL         "", IDC_UP_NOTES, "SysLink", WS_TABSTOP, 10, 76, 280, 12
    CONTROL         "", IDC_UP_PROGRESS, "msctls_progress32", WS_BORDER, 10, 98, 280, 10
    CTEXT           "",  IDC_UP_STATUS,   10, 112, 280, 11
    PUSHBUTTON      "Update Now",      IDC_UP_NOW,     14, 150, 84, 18
    PUSHBUTTON      "Later",           IDCANCEL,      108, 150, 60, 18
    PUSHBUTTON      "Don't Ask Again", IDC_UP_DONTASK,178, 150, 108, 18
END

// Name input dialog (new profile)
IDD_NAME DIALOGEX 0, 0, 220, 80
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "New Profile"
FONT 11, "Segoe UI", 400, 0, 0x0
BEGIN
    LTEXT           "Profile name:", IDC_NAME_PROMPT, 10, 12, 200, 10
    EDITTEXT        IDC_NAME_EDIT,   10, 28, 200, 13, ES_AUTOHSCROLL | WS_TABSTOP
    DEFPUSHBUTTON   "OK",            IDOK,      100, 54, 50, 14
    PUSHBUTTON      "Cancel",        IDCANCEL,  158, 54, 50, 14
END

