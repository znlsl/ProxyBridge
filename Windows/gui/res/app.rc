IDD_ABOUT DIALOGEX 0, 0, 250, 170
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About ProxyBridge"
FONT 11, "Segoe UI", 400, 0, 0x0
BEGIN
    CTEXT           "ProxyBridge",  IDC_AB_TITLE,    0,  12, 250, 18
    CTEXT           "",             IDC_AB_VER,      0,  33, 250, 11
    CTEXT           "",             IDC_AB_DESC,     6,  50, 238, 11
    CTEXT           "",             IDC_AB_AUTHOR,   0,  67, 250, 11
    CONTROL         "", IDC_AB_WEB,    "SysLink", WS_TABSTOP, 0, 86, 250, 12
    CONTROL         "", IDC_AB_GITHUB, "SysLink", WS_TABSTOP, 0, 103, 250, 12
    CTEXT           "",             IDC_AB_LICENSE,  0, 122, 250, 11
